{
    "title": "Virtual Boiler - Реал-тайм мониторинг",
    "uid": "boiler-main",
    "version": 1,
    "panels": [
        {
            "title": "Температура топки и Давление пара",
            "type": "timeseries",
            "targets": [
                {
                    "query": "from(bucket: \"telemetry\") |> filter(fn: (r) => r._measurement == \"boiler_telemetry\") |> filter(fn: (r) => r._field == \"temperature\")"
                },
                {
                    "query": "from(bucket: \"telemetry\") |> filter(fn: (r) => r._measurement == \"boiler_telemetry\") |> filter(fn: (r) => r._field == \"pressure\")"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "°C / bar"
                }
            }
        },
        {
            "title": "Подача топлива (Gauge)",
            "type": "gauge",
            "targets": [
                {
                    "query": "from(bucket: \"telemetry\") |> filter(fn: (r) => r._measurement == \"boiler_telemetry\") |> filter(fn: (r) => r._field == \"fuel\") |> last()"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100,
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "orange",
                                "value": 70
                            },
                            {
                                "color": "red",
                                "value": 90
                            }
                        ]
                    }
                }
            }
        },
        {
            "title": "Уровень в барабане",
            "type": "stat",
            "targets": [
                {
                    "query": "from(bucket: \"telemetry\") |> filter(fn: (r) => r._field == \"drum_level\") |> last()"
                }
            ]
        }
    ],
    "time": {
        "from": "now-30m",
        "to": "now"
    }
}